# 통합 Dockerfile 빌드 컨텍스트는 루트 — 불필요/민감 파일 제외.
**/node_modules
**/dist
**/build
**/.next
**/out
**/*.log
**/.DS_Store
**/.vscode
**/.idea

.git
.gitignore

# env 는 빌드 산출물에 포함되면 안됨. backend/.env 는 런타임에서 env_file 로 주입.
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# 다른 컨테이너용 산출물
playwright/

# 컨테이너 내부 업로드 디렉토리는 named volume — 빌드 컨텍스트에 포함 X.
backend/uploads
