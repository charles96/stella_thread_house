# Stella's Thread House — docker compose env (선택). 모든 값은 기본값이 있으므로
# 보통은 따로 .env 를 만들지 않아도 동작. 필요한 항목만 복사해서 .env 에 채우면 됨.

# --- Postgres ---
POSTGRES_DB=stella
POSTGRES_USER=stella
POSTGRES_PASSWORD=stella_dev_pass

# --- Frontend ---
# 브라우저는 항상 same-origin /api/* 로 호출 → Next 가 백엔드로 프록시. 별도 env 불필요.

# --- Backend ---
TH_HOST=http://localhost:3100
# OLLAMA_URL — 부팅 시 DB 'ai' row 가 비어있으면 이 값으로 시드.
# 이후 Settings > AI 에서 admin 이 변경하면 DB 값이 우선.
OLLAMA_URL=http://ai.example.com
# TAVILY_API_KEY — 부팅 시 DB 'tavily' row 가 비어있으면 이 값으로 시드.
# 이후 Settings > AI > Tools 에서 admin 이 변경한 DB 값이 우선.
TAVILY_API_KEY=

# --- 부팅 관리자 — 첫 가입 시(사용자 0명) 이 이메일/비밀번호와 일치해야만 admin 으로 등록.
# 운영 환경에서는 반드시 강력한 값으로 교체하고 .env 만 사용 (커밋 금지).
TH_ADMIN_EMAIL_ID=charles77@gmail.com
TH_ADMIN_PASSWORD=changeme1234
