# --- Postgres ---
POSTGRES_DB=stella
POSTGRES_USER=stella
POSTGRES_PASSWORD=stella_dev_pass

# --- Backend ---
# OLLAMA_GEMMA4_URL — 부팅 시 DB 'ai' row 가 비어있으면 이 값으로 시드.
# 이후 Settings > AI 에서 admin 이 변경하면 DB 값이 우선.
OLLAMA_GEMMA4_URL=http://ai.example.com
TAVILY_API_KEY=

TH_HOST=http://localhost:3100
TH_ADMIN_EMAIL_ID=your-email@example.com
TH_ADMIN_PASSWORD=changeme1234

# --- User setting defaults (overridden per-user via Settings UI) ---
SEARCH_TOP_READ=3
HASHTAG_THRESHOLD_DEFAULT=3
