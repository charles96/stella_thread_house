# --- Postgres ---
POSTGRES_DB=stella
POSTGRES_USER=stella
POSTGRES_PASSWORD=stella_dev_pass

# --- Backend ---
TAVILY_API_KEY=

# --- AI provider (DB 'ai' row 가 비어있을 때만 시드. 이후 Settings 값 우선) ---
# AI_PROVIDER: ollama | openai-compatible
AI_PROVIDER=ollama
# Ollama base URL (예: http://host:11434). /v1 없음.
OLLAMA_BASE_URL=http://ai.example.com:11434
# (레거시 별칭) OLLAMA_BASE_URL 미설정 시 폴백. 신규 설정은 OLLAMA_BASE_URL 사용.
# OLLAMA_GEMMA4_URL=
# OpenAI 호환 base URL (/v1 까지 포함, /chat/completions 제외). 예: https://api.openai.com/v1
OPENAI_BASE_URL=
# OpenAI 호환 API 키 (Ollama 는 불필요)
OPENAI_API_KEY=

# Email invitation link base URL (change to your domain in production)
TH_HOST=http://localhost:3100
TH_PORT=3100
TH_ADMIN_EMAIL_ID=your-email@example.com
TH_ADMIN_PASSWORD=changeme1234

SEARCH_TOP_READ=3
HASHTAG_THRESHOLD_DEFAULT=3

# --- SMTP (email delivery) ---
# Used as fallback when DB has no SMTP config. Settings > General > SMTP takes priority.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=no-reply@example.com
# SMTP_SECURE=1  # Enable when using port 465 (TLS)