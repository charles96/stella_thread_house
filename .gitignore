backend/build/

# Frontend (Next.js)
frontend/.next/
frontend/out/
frontend/build/
frontend/dist/
frontend/next-env.d.ts

# TypeScript incremental build info (어느 패키지든)
*.tsbuildinfo
tsconfig.tsbuildinfo

# ───── Environment / Secrets ─────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
!.env.example

# ───── Logs ─────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/

# ───── Caches ─────
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.turbo/
.swc/
.next/
.nyc_output/

# ───── Test / Coverage ─────
coverage/
