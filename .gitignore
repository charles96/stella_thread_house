credentials.json
secrets/

# ───── 사용자 첨부 / 런타임 산출물 — 루트 한정. 소스의 같은 이름 디렉토리는 영향 X. ─────
/uploads/
/attachments/
/runtime/
/data/

# ───── AI 코드 어시스턴트 캐시 ─────
.aider*
.codex/
.continue/
.windsurf/
.copilot/

# ───── 압축 / 아카이브 (실수 커밋 방지) ─────
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z

# 단, db/init 같이 의도적으로 커밋되는 sql 파일은 유지.
!db/init/*.sql
