.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.iml
*.sublime-workspace
*.sublime-project
*.swp
*.swo

# ───── OS-specific ─────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

